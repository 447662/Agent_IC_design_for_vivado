{
  "name": "sync-fifo",
  "display_name": "Synchronous FIFO",
  "design_family": "fifo",
  "handler": "sync-fifo",
  "aliases": [
    "sync_fifo",
    "syncfifo"
  ],
  "flows": [
    "generate-rtl",
    "sim-rtl",
    "analyze-rtl-vcd",
    "check-rtl",
    "open-wave"
  ],
  "description": "Single-clock FIFO with Vivado/xsim simulation, VCD/RWave analysis, and WDB GUI flow.",
  "parameters": [
    {"name": "DATA_WIDTH", "default": "8", "description": "FIFO 数据位宽"},
    {"name": "ADDR_WIDTH", "default": "4", "description": "FIFO 地址位宽，深度为 2**ADDR_WIDTH"}
  ],
  "interfaces": [
    {"name": "clk", "direction": "input", "width": "1", "description": "单时钟域时钟"},
    {"name": "rst_n", "direction": "input", "width": "1", "description": "低有效复位"},
    {"name": "wr_en", "direction": "input", "width": "1", "description": "写请求"},
    {"name": "wr_data", "direction": "input", "width": "DATA_WIDTH", "description": "写数据"},
    {"name": "rd_en", "direction": "input", "width": "1", "description": "读请求"},
    {"name": "rd_data", "direction": "output", "width": "DATA_WIDTH", "description": "读数据"},
    {"name": "full", "direction": "output", "width": "1", "description": "FIFO 满标志"},
    {"name": "empty", "direction": "output", "width": "1", "description": "FIFO 空标志"}
  ],
  "checks": [
    "write only advances when wr_en and not full",
    "read only advances when rd_en and not empty",
    "read data order matches write order",
    "full and empty never assert together outside reset"
  ],
  "scenario_catalog": [
    {"id": "basic_ordered", "type": "functional", "purpose": "基础有序写入与读取", "status": "PASS"},
    {"id": "full_boundary", "type": "boundary", "purpose": "写满边界", "status": "PASS"},
    {"id": "empty_boundary", "type": "boundary", "purpose": "读空边界", "status": "PASS"},
    {"id": "mixed_stress", "type": "stress", "purpose": "读写混合压力", "status": "PASS"}
  ],
  "coverage_metrics": [
    {"id": "statement", "label": "Statement coverage", "source": "not-enabled", "status": "SKIP"},
    {"id": "branch", "label": "Branch coverage", "source": "not-enabled", "status": "SKIP"},
    {"id": "condition", "label": "Condition coverage", "source": "not-enabled", "status": "SKIP"},
    {"id": "toggle", "label": "Toggle coverage", "source": "not-enabled", "status": "SKIP"},
    {"id": "functional", "label": "Functional coverage", "source": "no-uvm-flow", "status": "N/A"}
  ],
  "artifact_manifest": [
    {"id": "design_spec", "path": "reports/design_spec.md", "status": "PASS"},
    {"id": "verification_plan", "path": "reports/verification_plan.md", "status": "PASS"},
    {"id": "rtl", "path": "rtl/sync_fifo.v", "status": "PASS"},
    {"id": "testbench", "path": "tb/tb_sync_fifo.v", "status": "PASS"},
    {"id": "vivado_sim", "path": "sim/run_vivado_sync_fifo.tcl", "status": "PASS"},
    {"id": "sim_report", "path": "reports/sim_report.md", "status": "PASS"},
    {"id": "wave_vcd", "path": "sim/sync_fifo_trace.vcd", "status": "PASS"},
    {"id": "wave_wdb", "path": "sim/sync_fifo_smoke.wdb", "status": "PASS"},
    {"id": "coverage_summary", "path": "reports/uvm_coverage_summary.md", "status": "N/A"}
  ],
  "notes": [
    "该目标用于验证通用 flow 不依赖异步跨时钟结构。"
  ]
}
