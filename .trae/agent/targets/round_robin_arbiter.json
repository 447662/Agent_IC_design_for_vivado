{
  "name": "round-robin-arbiter",
  "display_name": "Round-Robin Arbiter",
  "design_family": "arbiter",
  "handler": "round-robin-arbiter",
  "aliases": [
    "round_robin_arbiter",
    "roundrobinarbiter",
    "rr-arbiter",
    "rr_arbiter"
  ],
  "flows": [
    "generate-rtl",
    "sim-rtl",
    "analyze-rtl-vcd",
    "check-rtl",
    "open-wave"
  ],
  "description": "Four-requester round-robin arbiter with Vivado/xsim simulation, fairness scenarios, VCD/RWave analysis, and WDB GUI flow.",
  "parameters": [
    {"name": "REQ_WIDTH", "default": "4", "description": "请求端口数量，当前目标固定覆盖 4 requester"}
  ],
  "interfaces": [
    {"name": "clk", "direction": "input", "width": "1", "description": "仲裁时钟"},
    {"name": "rst_n", "direction": "input", "width": "1", "description": "低有效复位"},
    {"name": "req[3:0]", "direction": "input", "width": "4", "description": "请求向量"},
    {"name": "grant[3:0]", "direction": "output", "width": "4", "description": "授权向量，期望 one-hot grant"},
    {"name": "grant_valid", "direction": "output", "width": "1", "description": "授权有效标志"}
  ],
  "checks": [
    "one-hot grant when grant_valid is asserted",
    "grant implies request",
    "rotating priority advances after accepted grant",
    "fairness window prevents starvation under sustained requests",
    "reset recovery restarts priority from requester 0"
  ],
  "scenario_catalog": [
    {"id": "single_request", "type": "functional", "purpose": "单请求授权", "status": "PASS"},
    {"id": "multiple_requests", "type": "functional", "purpose": "多请求优先级轮转", "status": "PASS"},
    {"id": "rotating_grant", "type": "fairness", "purpose": "连续授权轮转", "status": "PASS"},
    {"id": "reset_recovery", "type": "recovery", "purpose": "复位恢复", "status": "PASS"},
    {"id": "fairness_window", "type": "fairness", "purpose": "公平性窗口", "status": "PASS"}
  ],
  "coverage_metrics": [
    {"id": "statement", "label": "Statement coverage", "source": "not-enabled", "status": "SKIP"},
    {"id": "branch", "label": "Branch coverage", "source": "not-enabled", "status": "SKIP"},
    {"id": "condition", "label": "Condition coverage", "source": "not-enabled", "status": "SKIP"},
    {"id": "toggle", "label": "Toggle coverage", "source": "not-enabled", "status": "SKIP"},
    {"id": "functional", "label": "Functional coverage", "source": "no-uvm-flow", "status": "N/A"}
  ],
  "artifact_manifest": [
    {"id": "design_spec", "path": "reports/design_spec.md", "status": "PASS"},
    {"id": "verification_plan", "path": "reports/verification_plan.md", "status": "PASS"},
    {"id": "rtl", "path": "rtl/round_robin_arbiter.v", "status": "PASS"},
    {"id": "testbench", "path": "tb/tb_round_robin_arbiter.v", "status": "PASS"},
    {"id": "vivado_sim", "path": "sim/run_vivado_round_robin_arbiter.tcl", "status": "PASS"},
    {"id": "sim_report", "path": "reports/sim_report.md", "status": "PASS"},
    {"id": "wave_vcd", "path": "sim/round_robin_arbiter_trace.vcd", "status": "PASS"},
    {"id": "wave_wdb", "path": "sim/round_robin_arbiter_smoke.wdb", "status": "PASS"},
    {"id": "coverage_summary", "path": "reports/uvm_coverage_summary.md", "status": "N/A"}
  ],
  "notes": [
    "P5.3 首个非 FIFO 控制逻辑目标，适合作为通用数字 IC Agent 扩展样例。"
  ]
}
