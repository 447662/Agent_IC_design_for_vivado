{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/447662/Agent_IC_design_for_vivado/schemas/verification-intent.schema.json",
  "title": "VerificationIntent",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "module", "testbench_top", "source_files", "include_dirs", "uvm_enabled", "timescale", "pass_markers", "directed_scenarios", "random_constraints", "scoreboard", "assertions", "functional_coverage", "code_coverage", "coverage_strategy", "iteration_limits", "exit_criteria"],
  "properties": {
    "schema_version": {"const": "digital-ic-agent.verification-intent.v1"},
    "module": {"type": "string"},
    "testbench_top": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
    "source_files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "include_dirs": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "uvm_enabled": {"type": "boolean"},
    "timescale": {"type": "string", "pattern": "^[1-9][0-9]*(s|ms|us|ns|ps|fs)/[1-9][0-9]*(s|ms|us|ns|ps|fs)$"},
    "pass_markers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "directed_scenarios": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/check"}},
    "random_constraints": {"type": "array", "items": {"$ref": "#/$defs/check"}},
    "scoreboard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "strategy", "compare_signals"],
      "properties": {
        "enabled": {"type": "boolean"},
        "strategy": {"type": "string"},
        "compare_signals": {"type": "array", "items": {"type": "string"}}
      }
    },
    "assertions": {"type": "array", "items": {"$ref": "#/$defs/check"}},
    "functional_coverage": {"type": "array", "items": {"$ref": "#/$defs/check"}},
    "code_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "branch", "condition", "toggle"],
      "properties": {
        "statement": {"type": "number", "minimum": 0, "maximum": 100},
        "branch": {"type": "number", "minimum": 0, "maximum": 100},
        "condition": {"type": "number", "minimum": 0, "maximum": 100},
        "toggle": {"type": "number", "minimum": 0, "maximum": 100}
      }
    },
    "coverage_strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code_coverage", "functional_coverage", "export_report", "functional_threshold"],
      "properties": {
        "code_coverage": {"type": "boolean"},
        "functional_coverage": {"type": "boolean"},
        "export_report": {"type": "boolean"},
        "functional_threshold": {"type": "number", "minimum": 0, "maximum": 100}
      }
    },
    "iteration_limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_iterations", "max_time_seconds", "no_progress_limit"],
      "properties": {
        "max_iterations": {"type": "integer", "minimum": 1, "maximum": 100},
        "max_time_seconds": {"type": "integer", "minimum": 1, "maximum": 86400},
        "no_progress_limit": {"type": "integer", "minimum": 1, "maximum": 100}
      }
    },
    "exit_criteria": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zero_uvm_errors", "zero_uvm_fatals", "scoreboard_pass", "all_assertions_pass", "coverage_must_pass"],
      "properties": {
        "zero_uvm_errors": {"type": "boolean"},
        "zero_uvm_fatals": {"type": "boolean"},
        "scoreboard_pass": {"type": "boolean"},
        "all_assertions_pass": {"type": "boolean"},
        "coverage_must_pass": {"type": "boolean"}
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description"],
      "properties": {
        "id": {"type": "string"},
        "description": {"type": "string"},
        "expected": {"type": "string"},
        "signals": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
