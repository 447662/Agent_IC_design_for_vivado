    {
      "kind": "repair",
      "cases": [
        {
          "id": "repair-timer-syntax",
          "specification": "Repair a timer source file with a SystemVerilog syntax error and prove compile recovery.",
          "spec_sha256": "9257f492d657967a2b5cb86859f81734f118e4973ef4e9997665fb4ff37d4e30",
          "design_template": "timer",
          "evidence_kind": "real-vivado-repair",
          "max_repair_iterations": 3,
          "defect": {
            "id": "timer-syntax",
            "type": "syntax",
            "file": "rtl/timer.sv",
            "expected_reason_codes": ["NONZERO_EXIT", "TOOL_ERROR_FOUND"],
            "injection": {"operation": "replace_once", "find": "expired   <= 1'b0;", "replace": "expired   <= ;"}
          }
        },
        {
          "id": "repair-timer-off-by-one",
          "specification": "Repair a timer whose expiry comparison is off by one and prove scoreboard recovery.",
          "spec_sha256": "d8dffa3da9c6f4dbdc711160e489651d2d9d11c5d465c678960d50cf1b317186",
          "design_template": "timer",
          "evidence_kind": "real-vivado-repair",
          "max_repair_iterations": 3,
          "defect": {
            "id": "timer-off-by-one",
            "type": "behavior",
            "file": "rtl/timer.sv",
            "expected_reason_codes": ["FAIL_MARKER_FOUND"],
            "injection": {"operation": "replace_once", "find": "if (remaining <= {{(WIDTH-1){1'b0}}, 1'b1}) begin", "replace": "if (remaining <= 2) begin"}
          }
        },
        {
          "id": "repair-timer-reset",
          "specification": "Repair a timer with inverted reset polarity and prove assertion recovery.",
          "spec_sha256": "c2a266223b5c3ba5e59448142bb4030837a21e1cd8507d1d26e1b29aabbc218f",
          "design_template": "timer",
          "evidence_kind": "real-vivado-repair",
          "max_repair_iterations": 3,
          "defect": {
            "id": "timer-reset-polarity",
            "type": "behavior",
            "file": "rtl/timer.sv",
            "expected_reason_codes": ["FAIL_MARKER_FOUND", "UVM_ERROR_FOUND"],
            "injection": {"operation": "replace_once", "find": "if (!rst_n) begin", "replace": "if (rst_n) begin"}
          }
        },
        {
          "id": "repair-apb-address-decode",
